# Copy to `.env` for local use with: deno run --allow-env --allow-read --allow-write --allow-net --allow-sys main.ts --server
# On Deno Deploy: Project → Settings → Environment Variables (same names).

# --- https://solden.atomiclabs.cc/ (same app serves UI + API) ---
# Usually leave CORS unset. Optional:
# LOG_LEVEL=info
# LOG_JSON=1

# --- Only if the browser UI is on a different origin than this API ---
# ACCESS_CONTROL_ALLOW_ORIGIN=https://solden.atomiclabs.cc

# --- Optional ---
# PORT=3737
