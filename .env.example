# Copy to `.env` for local use with: deno run --allow-env --allow-read --allow-write --allow-net --allow-sys main.ts --server
# On Deno Deploy: Project → Settings → Environment Variables (same names).

# --- https://solden.atomiclabs.cc/ (same app serves UI + API) ---
# Usually leave CORS unset. Optional:
# LOG_LEVEL=info
# LOG_JSON=1

# --- CORS (only if UI is on a DIFFERENT host than this API) ---
# Comma-separated allowed origins. Must match the browser tab URL exactly.
# ACCESS_CONTROL_ALLOW_ORIGIN=https://solden.atomiclabs.cc
# Local dev: leave unset when UI+API are both http://127.0.0.1:3737 (same host auto-allowed).
# Or: VANITY_CORS_ALLOW_LOCALHOST=1 with ACCESS_CONTROL_ALLOW_ORIGIN set for production.
# VANITY_CORS_ALLOW_LOCALHOST=1

# --- Deno Deploy / HTTP tuning (see README) ---
# VANITY_HTTP_EPHEMERAL=1
# VANITY_HTTP_PERSIST_HITS=1
# VANITY_SSE_LOG_PULSE=1
# VANITY_DEPLOY_MAX_WORKERS=8
# VANITY_DEPLOY_MEMORY_BUDGET_MB=256
# VANITY_DEPLOY_MB_PER_WORKER=48

# --- Admin (separate page at /admin.html; 4 quick taps on logo on main UI) ---
# VANITY_ADMIN_PASSWORD=your-secret-here

# --- Keygen throughput (local; ~500k keys/s needs many cores + fast backend) ---
# VANITY_KEYGEN=auto
# VANITY_KEYGEN_BATCH=64
# npm i sodium-native @noble/ed25519 @noble/hashes   # optional; auto-picks fastest

# --- Optional local ---
# PORT=3737
