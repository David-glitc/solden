{
  "nodeModulesDir": "auto",
  "unstable": ["kv"],
  "imports": {},
  "tasks": {
    "start":   "deno run --allow-read --allow-write --allow-net --allow-sys main.ts",
    "server":  "deno run --allow-read --allow-write --allow-net --allow-sys main.ts --server",
    "dev":     "deno run --allow-read --allow-write --allow-net --allow-sys main.ts --server -v",
    "grind":   "deno run --allow-read --allow-write --allow-net main.ts --",
    "grind-fast": "deno run --allow-read --allow-write --allow-net main.ts -- -B 1.25 -g 1024 -u 120",
    "bun-grind": "bun main.ts",
    "bun-fast": "bun main.ts -B 1.5 -g 1024 -u 150 -v",
    "server-ui": "deno run --allow-read --allow-write --allow-net --allow-sys main.ts --server",
    "deploy": "deno deploy .",
    "bench":   "deno bench benchmarks/meth_prefix_keygen.bench.ts",
    "check":   "deno check main.ts",
    "decrypt": "deno run --allow-read decrypt.ts"
  }
}
